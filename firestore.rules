rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Global Safety Net: Deny all by default
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Global Helpers
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // Collection: Users
    // -------------------------------------------------------------------------
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['email']) &&
               data.email is string && data.email.size() <= 256 &&
               (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128)) &&
               (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1024)) &&
               (!('lastSeen' in data) || (data.lastSeen is string));
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastSeen']);
    }

    // -------------------------------------------------------------------------
    // Collection: History
    // -------------------------------------------------------------------------
    match /users/{userId}/history/{date} {
      function isValidHistory(data) {
        return data.keys().hasAll(['log', 'analysis', 'date']) &&
               data.log is map && data.analysis is map && data.date is string &&
               data.log.transport is string && data.log.transport.size() <= 1000 &&
               data.log.food is string && data.log.food.size() <= 1000 &&
               data.log.energy is string && data.log.energy.size() <= 1000 &&
               data.analysis.score is number && data.analysis.score >= 0 && data.analysis.score <= 100 &&
               data.analysis.grade is string && data.analysis.grade.size() <= 100 &&
               data.analysis.pros is list && data.analysis.pros.size() <= 10 &&
               data.analysis.swaps is list && data.analysis.swaps.size() <= 10 &&
               data.analysis.encouragement is string && data.analysis.encouragement.size() <= 1000;
      }

      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidHistory(incoming()) && isValidId(date);
      allow update: if isOwner(userId) && isValidHistory(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['log', 'analysis']);
      allow delete: if isOwner(userId);
    }
  }
}
